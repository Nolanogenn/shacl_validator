        sh:datatype  xsd:string .

MovieSHACL3:Film-country
        rdf:type     sh:PropertyShape;
        sh:name      "country";
        sh:path      MovieSHACL3:country;
        sh:datatype  xsd:string .

MovieSHACL3:Film-productionCompany
        rdf:type     sh:PropertyShape;
        sh:name      "productionCompany";
        sh:path      MovieSHACL3:productionCompany;
        sh:datatype  xsd:string .

MovieSHACL3:Film-budget
        rdf:type          sh:PropertyShape;
        sh:name           "budget";
        sh:path           MovieSHACL3:budget;
        sh:maxCount       1;
        sh:or             ( [ sh:datatype xsd:integer ] [ sh:datatype xsd:decimal ] );
        sh:minInclusive   0 .

MovieSHACL3:Film-revenue
        rdf:type          sh:PropertyShape;
        sh:name           "revenue";
        sh:path           MovieSHACL3:revenue;
        sh:maxCount       1;
        sh:datatype       xsd:integer;
        sh:minInclusive   0 .

MovieSHACL3:Film-tmdbRating
        rdf:type     sh:PropertyShape;
        sh:name      "tmdbRating";
        sh:path      MovieSHACL3:tmdbRating;
        sh:maxCount  1;
        sh:datatype  xsd:float .

MovieSHACL3:Film-tmdbPopularity
        rdf:type     sh:PropertyShape;
        sh:name      "tmdbPopularity";
        sh:path      MovieSHACL3:tmdbPopularity;
        sh:maxCount  1;
        sh:datatype  xsd:float .

MovieSHACL3:Film-originalLanguage
        rdf:type     sh:PropertyShape;
