MovieSHACL3:Film-runtime
        rdf:type          sh:PropertyShape;
        sh:name           "runtime";
        sh:path           MovieSHACL3:runtime;
        sh:maxCount       1;
        sh:datatype       xsd:integer;
        sh:minInclusive   1 .

MovieSHACL3:Film-genre
        rdf:type     sh:PropertyShape;
        sh:nodeKind  sh:IRI;
        sh:class     MovieSHACL3:Genre;
        sh:name      "hasGenre";
        sh:path      MovieSHACL3:hasGenre .

MovieSHACL3:Film-language
        rdf:type     sh:PropertyShape;
