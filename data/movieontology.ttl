# ── Forecast classes ────────────────────────────────────────────────────────

MovieSHACL3:ForecastSet
        rdfs:subClassOf  owl:Thing;
        rdf:type         owl:Class;
        rdfs:label       "ForecastSet";
        rdfs:comment     "A set of probabilistic predictions produced by one model run for a specific award category and ceremony year." .

MovieSHACL3:Forecast
        rdfs:subClassOf  owl:Thing;
        rdf:type         owl:Class;
        rdfs:label       "Forecast";
        rdfs:comment     "A single binary probabilistic prediction about whether a specific nominee will win an award." .

MovieSHACL3:hasForecast
        rdf:type         owl:ObjectProperty;
        rdfs:domain      MovieSHACL3:ForecastSet;
        rdfs:range       MovieSHACL3:Forecast;
        rdfs:label       "hasForecast" .

MovieSHACL3:predictsNomination
        rdf:type         owl:ObjectProperty;
        rdfs:domain      MovieSHACL3:Forecast;
        rdfs:range       MovieSHACL3:Nomination;
        rdfs:label       "predictsNomination";
        rdfs:comment     "Links a Forecast to the specific Nomination it predicts will resolve as a win." .

MovieSHACL3:forecastQuestion
        rdf:type         owl:DatatypeProperty;
        rdfs:domain      MovieSHACL3:Forecast;
        rdfs:range       xsd:string;
        rdfs:label       "forecastQuestion";
        rdfs:comment     "Natural-language question resolved by this forecast (e.g. 'Will X win the SAG Award for Best Actor (2025)?')." .

MovieSHACL3:forecastProbability
        rdf:type         owl:DatatypeProperty;
        rdfs:domain      MovieSHACL3:Forecast;
        rdfs:range       xsd:decimal;
        rdfs:label       "forecastProbability";
        rdfs:comment     "Model-assigned probability (0–1) that the linked nomination resolves as a win." .

MovieSHACL3:loggedAt
        rdf:type         owl:DatatypeProperty;
        rdfs:domain      MovieSHACL3:Forecast;
        rdfs:range       xsd:date;
        rdfs:label       "loggedAt";
        rdfs:comment     "Date on which this forecast was recorded, before the outcome was known." .

MovieSHACL3:forecastSetSystem
        rdf:type         owl:DatatypeProperty;
        rdfs:domain      MovieSHACL3:ForecastSet;
        rdfs:range       xsd:string;
        rdfs:label       "forecastSetSystem";
        rdfs:comment     "Award system alias (e.g. 'sag', 'oscars')." .

MovieSHACL3:forecastSetCategory
        rdf:type         owl:DatatypeProperty;
        rdfs:domain      MovieSHACL3:ForecastSet;
        rdfs:range       xsd:string;
        rdfs:label       "forecastSetCategory";
        rdfs:comment     "Category alias (e.g. 'best_actor', 'best_ensemble_cast')." .

MovieSHACL3:forecastSetYear
        rdf:type         owl:DatatypeProperty;
        rdfs:domain      MovieSHACL3:ForecastSet;
        rdfs:range       xsd:gYear;
        rdfs:label       "forecastSetYear";
        rdfs:comment     "Film year for which predictions were made." .

MovieSHACL3:forecastSetLoggedAt
        rdf:type         owl:DatatypeProperty;
        rdfs:domain      MovieSHACL3:ForecastSet;
        rdfs:range       xsd:date;
        rdfs:label       "forecastSetLoggedAt" .

MovieSHACL3:forecastSetModelType
        rdf:type         owl:DatatypeProperty;
        rdfs:domain      MovieSHACL3:ForecastSet;
        rdfs:range       xsd:string;
        rdfs:label       "forecastSetModelType";
        rdfs:comment     "Model type used (e.g. 'GB', 'LR+RF')." .

MovieSHACL3:forecastSetFeatures
        rdf:type         owl:DatatypeProperty;
        rdfs:domain      MovieSHACL3:ForecastSet;
        rdfs:range       xsd:string;
        rdfs:label       "forecastSetFeatures";
        rdfs:comment     "Comma-separated list of features used by the model." .

MovieSHACL3:forecastSetAUC
        rdf:type         owl:DatatypeProperty;
        rdfs:domain      MovieSHACL3:ForecastSet;
        rdfs:range       xsd:decimal;
        rdfs:label       "forecastSetAUC";
        rdfs:comment     "Backtest AUC of the model at time of logging." .

MovieSHACL3:forecastSetTop1Pct
        rdf:type         owl:DatatypeProperty;
        rdfs:domain      MovieSHACL3:ForecastSet;
        rdfs:range       xsd:decimal;
        rdfs:label       "forecastSetTop1Pct";
        rdfs:comment     "Backtest top-1 accuracy (0–1) of the model at time of logging." .

MovieSHACL3:forecastSetSource
        rdf:type         owl:DatatypeProperty;
        rdfs:domain      MovieSHACL3:ForecastSet;
        rdfs:range       xsd:string;
        rdfs:label       "forecastSetSource";
        rdfs:comment     "Origin of the forecast probabilities: 'model' for ML model output, 'kalshi_market' for Kalshi prediction market prices." .

# ── OWL property declarations for Film, Person, Nomination, and related classes ─
# These mirror the sh:path values in the SHACL PropertyShapes above so that EDG
# recognises them as queryable RDF properties in its SPARQL interface.

